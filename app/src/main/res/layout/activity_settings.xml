<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Настройки SSH" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText android:id="@+id/editSshIp" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="IP сервера" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/editSshPort" android:layout_width="80dp" android:layout_height="wrap_content" android:hint="Порт" android:text="22" android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText android:id="@+id/editSshUser" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Пользователь" android:text="root" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/editSshPass" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Пароль" android:inputType="textPassword" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Настройки vk-turn-proxy (Сервер)" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText android:id="@+id/editProxyListen" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Listen (напр. 0.0.0.0:56000)" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64" android:layout_marginEnd="8dp" android:textSize="12sp"/>
        <EditText android:id="@+id/editProxyConnect" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Connect (напр. 127.0.0.1:40537)" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64" android:textSize="12sp"/>
    </LinearLayout>

    <Button android:id="@+id/btnConnectSsh" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ПОДКЛЮЧИТЬСЯ И ОТКРЫТЬ ТЕРМИНАЛ" android:backgroundTint="#F57C00" android:layout_marginTop="8dp"/>

    <Button android:id="@+id/btnInstallServer" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="УСТАНОВИТЬ / ОБНОВИТЬ VK-TURN-PROXY" android:backgroundTint="#2E7D32" android:enabled="false" android:layout_marginTop="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
        <Button android:id="@+id/btnStartProxy" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="ЗАПУСТИТЬ" android:backgroundTint="#43A047" android:enabled="false" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnStopProxy" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="ОСТАНОВИТЬ" android:backgroundTint="#D32F2F" android:enabled="false" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp" android:gravity="center_vertical">
        <EditText android:id="@+id/editCustomCmd" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Команда" android:textColor="#FFFFFF" android:textColorHint="#757575" android:backgroundTint="#455A64" android:fontFamily="monospace"/>
        <Button android:id="@+id/btnCtrlC" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CTRL+C" android:backgroundTint="#B71C1C" android:layout_marginStart="4dp" android:textSize="12sp" android:padding="8dp"/>
        <Button android:id="@+id/btnSendCmd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEND" android:backgroundTint="#1976D2" android:layout_marginStart="4dp" android:textSize="12sp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#263238" android:padding="4dp" android:layout_marginTop="8dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="#CFD8DC" android:padding="4dp" android:text="SSH ТЕРМИНАЛ:" android:textSize="12sp" android:textStyle="bold" />
        <Button android:id="@+id/btnCopySshLog" style="?android:attr/buttonStyleSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COPY" android:textSize="10sp" android:backgroundTint="#455A64"/>
        <Button android:id="@+id/btnClearSshLog" style="?android:attr/buttonStyleSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CLEAR" android:layout_marginStart="4dp" android:textSize="10sp" android:backgroundTint="#455A64"/>
    </LinearLayout>

    <ScrollView android:id="@+id/scrollSshLog" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:background="#000000">
        <TextView android:id="@+id/tvSshLog" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#4CAF50" android:textSize="12sp" android:padding="10dp" android:fontFamily="monospace" android:textIsSelectable="true" android:text="Ожидание действий...\n" />
    </ScrollView>

    <Button android:id="@+id/btnBack" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="НАЗАД" android:backgroundTint="#455A64" android:layout_marginTop="8dp"/>
</LinearLayout>